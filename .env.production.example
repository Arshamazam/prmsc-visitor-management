# App
NODE_ENV=production
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=
AUTH_SECRET=

# Database — Hostinger MariaDB credentials
DATABASE_URL=mysql://DB_USER:DB_PASSWORD@localhost:3306/DB_NAME

# Hostinger Object Storage (S3-compatible)
S3_ENDPOINT=https://your-bucket-endpoint
S3_HOSTNAME=your-bucket-hostname-only
S3_BUCKET=prmsc-vms
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=https://your-public-bucket-url
